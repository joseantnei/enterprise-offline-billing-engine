<Window x:Class="EnterpriseBilling.UI.Views.InvoiceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice Details" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC" Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderThickness="1" BorderBrush="#E2E8F0">
            <StackPanel>
                <TextBlock Text="INVOICE INFORMATION" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Invoice Number:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="lblInvoiceNumber" Text="---" FontSize="14" Margin="0,0,0,8" Foreground="#334155"/>

                        <TextBlock Text="Date &amp; Time:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="lblDate" Text="---" FontSize="14" Foreground="#334155"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Customer:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="lblCustomer" Text="---" FontSize="14" Margin="0,0,0,8" Foreground="#334155"/>

                        <TextBlock Text="Identification:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="lblId" Text="---" FontSize="14" Foreground="#334155"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgInvoiceDetails" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White" RowHeight="32" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product / Item" Binding="{Binding Product.NameProduct}" Width="*"/>
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C2}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Close Window" Height="40" Width="130" HorizontalAlignment="Left" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="CloseButton_Click"/>

            <StackPanel Grid.Column="1" MinWidth="200" VerticalAlignment="Center">
                <Grid Margin="0,2">
                    <TextBlock Text="Subtotal:" Foreground="#64748B"/>
                    <TextBlock x:Name="lblSubtotal" Text="$0.00" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
                <Grid Margin="0,2">
                    <TextBlock Text="Taxes:" Foreground="#64748B"/>
                    <TextBlock x:Name="lblTaxes" Text="$0.00" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
                <Separator Margin="0,5" Background="#E2E8F0"/>
                <Grid Margin="0,2">
                    <TextBlock Text="TOTAL PAID:" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock x:Name="lblTotal" Text="$0.00" HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" Foreground="#10B981"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>